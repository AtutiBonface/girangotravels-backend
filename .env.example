PORT=5000
NODE_ENV=development

DATABASE_URL=postgres://bonface:bonface123@localhost:5432/girango_travels
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=7d

GOOGLE_MAPS_API_KEY=
GOOGLE_PLACE_ID=
GOOGLE_REVIEWS_TTL_MINUTES=180

PING_AFRICA_BASE_URL=https://bulk.ping.africa/api
PING_AFRICA_API_KEY=
PING_AFRICA_SENDER_ID=PING-AFRICA
PING_AFRICA_WHATSAPP_INSTANCE_NAME=
ADMIN_ALERT_PHONE=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Frontend origin used by backend (links + CORS allowlist).
# Set APP_URL to your primary domain (for example: https://www.girangotravels.com).
APP_URL=http://localhost:3000
# Optional second frontend origin for CORS (for example non-www domain).
# If you use both domains, set this to the other one (for example: https://girangotravels.com).
# If you only use one domain, this can be the same as APP_URL.
PUBLIC_FRONTEND_URL=http://localhost:3000
SENDGRID_API_KEY=
UPLOAD_DIR=uploads

PAYSTACK_SECRET_KEY=
PAYSTACK_CALLBACK_URL=http://localhost:5000/api/payments/paystack/callback
PAYSTACK_CURRENCY=NGN
PAYSTACK_CURRENCY_FALLBACKS=USD,GHS,ZAR
FX_RATE_USD_NGN=1600
