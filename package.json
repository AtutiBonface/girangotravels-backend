  "description": "Express backend for Girango Travels with PostgreSQL, auth, bookings, payments, and Google reviews caching",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
